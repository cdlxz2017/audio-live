{
  "id": "memory-recall-plugin",
  "name": "Memory Recall Plugin",
  "description": "Injects recalled memories into agent prompts via before_prompt_build hook. Uses before_dispatch for senderId capture.",
  "version": "1.0.0",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true,
        "description": "Enable memory recall injection"
      },
      "topK": {
        "type": "number",
        "default": 5,
        "description": "Maximum number of memories to inject"
      },
      "tenantId": {
        "type": "string",
        "default": "00000000-0000-0000-0000-000000000000",
        "description": "Tenant ID for memory isolation"
      }
    }
  }
}
